<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="/stylesheets/style.css">
    <title>Document</title>
</head>
<body>
    <div class="w-full h-full bg-zinc-900  p-10 text-white relative" >
        <a class="text-blue-500" href="/">back</a>
        <h1 class="text-3xl tracking-tighter mb-3">All Users</h1>
        <div class="user max-w-72 p-4 bg-zinc-800 rounded-lg">
            <%if(users.length>0){%>
            <%users.forEach(function(user){%>
                <div class="w-full h-72 bg-red-500 rounded-lg bg-zinc-700 overflow-hidden">
                    <img clas="w-full h-full object-cover object-top" src="<%= user.image%>">
                </div>
                <h3 class="text-3xl mt-3 tracking tighter"><%=user.name%></h3>
                <h5 class="text-zinc-500"><%=user.email%></h5>
            <%})%>
            <div>
                <a class="text-zinc-200" href="/edit/<%=user._id%>">Edit User</a>
                <a class="text-red-500" href="/delete/<%=user._id%>">Delete User</a>
            </div>
            <%}else{%> 
                
                <h3 class="bg-zinc-500">No users Yet</h3>
                <%}%>
        </div>
    </div>
</body>
</html>