<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
     <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 text-white p-10">
        <h3 class="text-3xl mb-5">Create Acccount</h3>
        <form action="/register" method="post">
            <input type="text" class="px-3 py-2 rounded-md outline-none bg-transparent border-2 border-zinc-800" placeholder="name" name="name">
            <input type="text" class="px-3 py-2 rounded-md outline-none bg-transparent border-2 border-zinc-800" placeholder="username" name="usernname">
            <input type="number" class="px-3 py-2 rounded-md outline-none bg-transparent border-2 border-zinc-800" placeholder="age" name="age">
            <input type="email" class="px-3 py-2 rounded-md outline-none bg-transparent border-2 border-zinc-800" placeholder="email" name="email">
            <input type="password" class="px-3 py-2 rounded-md outline-none bg-transparent border-2 border-zinc-800" placeholder="password" name="password">
            <input type="submit" class="px-5 py-2 bg-blue-500 rounded-md" value="Create Account" >
        </form>
    </div>
</body>
</html>