<!DOCTYPE html>
<html>
<head>
  <title>Note Taking App</title>
   <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
  <div class="main w-full min-h-screen bg-zinc-900">
    <div class="form p-10 text-white">
        <form action="/create" method="POST">
            <input type="text" placeholder="Title" name="title" class="block w-full rounded-md outline-none px-5 py-2 bg-zinc-800">
            <textarea class="block w-full mt-2 px-5 py-2 resize-none bg-zinc-800" placeholder="Write your task details" name="details"></textarea>
            <button class="mt-2 bg-blue-600 px-5 py-2 rounded-md" type="submit" value="Create Task">Save Note</button>
        </form>
    </div>
    <div class="tasks flex gap-3 flex-wrap p-10">
  <% if(files.length > 0) { %>
    <% files.forEach(function(val) { %>
      <div class="task w-72 px-3 py-4 bg-zinc-800">
        <h1 class="text-white text-3xl tracking-tighter"><%= val %></h1>
        <div class="flex w-full justify-between inline-center mt-3">
          <a class="text-blue-500 inline-block" href="/files/<%= val %>">Read more.</a>
          <a class="text-zinc-600" href="/edit/<%=val%>">edit file name</a>
        </div>
       
      </div>
    <% }) %>
  <% } else { %>
    <h3 class="text-zinc-600">No tasks yet</h3>
  <% } %>
</div>

  </div>
</body>
</html>
